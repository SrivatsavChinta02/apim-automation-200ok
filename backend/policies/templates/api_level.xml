<policies>
  <inbound>
    <base />
    <set-header name="X-Global-Transaction-Id" exists-action="override">
      <value>@(Guid.NewGuid().ToString())</value>
    </set-header>
    <validate-jwt header-name="Authorization"
                  failed-validation-httpcode="401"
                  failed-validation-error-message="Unauthorized. Invalid or missing token.">
      <openid-config url="https://login.microsoftonline.com/TENANT_ID_PLACEHOLDER/.well-known/openid-configuration" />
      <required-claims>
        <claim name="aud">
          <value>JWT_AUDIENCE_PLACEHOLDER</value>
        </claim>
      </required-claims>
    </validate-jwt>
    CLIENT_CERT_BLOCK_PLACEHOLDER
    <set-variable name="consumer-name" value='@(context.Request.Headers.GetValueOrDefault("consumer-name", "").ToLowerInvariant())' />
    <rate-limit-by-key calls="RATE_LIMIT_CALLS_PLACEHOLDER"
                       renewal-period="RATE_LIMIT_RENEWAL_PLACEHOLDER"
                       counter-key='@((string)context.Variables["consumer-name"])'
                       increment-condition="@(true)" />
    <quota-by-key calls="QUOTA_CALLS_PLACEHOLDER"
                  renewal-period="QUOTA_PERIOD_PLACEHOLDER"
                  counter-key='@((string)context.Variables["consumer-name"])'
                  increment-condition="@(true)" />
    <choose>
      <when condition='@{
        var body = context.Request.Body?.As<string>(preserveContent: true) ?? "";
        return System.Text.RegularExpressions.Regex.IsMatch(body,
          @"(?i)(union\s+select|drop\s+table|insert\s+into|exec\s*\(|xp_cmdshell)");
      }'>
        <return-response>
          <set-status code="400" reason="Bad Request" />
          <set-header name="Content-Type" exists-action="override">
            <value>application/json</value>
          </set-header>
          <set-body>{"error":{"code":"400","message":"SQL injection pattern detected in request."}}</set-body>
        </return-response>
      </when>
    </choose>
    <set-backend-service backend-id="BACKEND_ID_PLACEHOLDER" />
    <set-header name="X-Consumer-Name" exists-action="override">
      <value>@((string)context.Variables["consumer-name"])</value>
    </set-header>
  </inbound>
  <backend>
    BACKEND_POLICY_PLACEHOLDER
  </backend>
  <outbound>
    <base />
    <set-header name="X-Correlation-Id" exists-action="override">
      <value>@(context.RequestId.ToString())</value>
    </set-header>
    <set-header name="X-Consumer-Name" exists-action="override">
      <value>@((string)context.Variables["consumer-name"])</value>
    </set-header>
  </outbound>
  <on-error>
    <base />
    <set-header name="Access-Control-Allow-Origin" exists-action="override">
      <value>*</value>
    </set-header>
    <set-header name="Content-Type" exists-action="override">
      <value>application/json</value>
    </set-header>
    <choose>
      <when condition='@(context.LastError.Source == "validate-jwt")'>
        <set-status code="401" reason="Unauthorized" />
        <set-body>{"error":{"code":"401","message":"Invalid or expired token. Obtain a fresh token from Azure AD."}}</set-body>
      </when>
      <when condition='@(context.LastError.Source == "rate-limit-by-key")'>
        <set-status code="429" reason="Too Many Requests" />
        <set-header name="Retry-After" exists-action="override">
          <value>60</value>
        </set-header>
        <set-body>{"error":{"code":"429","message":"Rate limit exceeded. Maximum RATE_LIMIT_CALLS_PLACEHOLDER calls per minute per application."}}</set-body>
      </when>
      <when condition='@(context.LastError.Source == "quota-by-key")'>
        <set-status code="429" reason="Too Many Requests" />
        <set-body>{"error":{"code":"429","message":"Daily quota exceeded. Maximum QUOTA_CALLS_PLACEHOLDER calls per day per application."}}</set-body>
      </when>
      <when condition='@(context.LastError.Source == "validate-content")'>
        <set-status code="400" reason="Bad Request" />
        <set-body>@("{\"error\":{\"code\":\"400\",\"message\":\"" + context.LastError.Message.Replace("\"", "'") + "\"}}")</set-body>
      </when>
      <otherwise>
        <set-status code="500" reason="Internal Server Error" />
        <set-body>@("{\"error\":{\"code\":\"500\",\"message\":\"" + context.LastError.Message.Replace("\"", "'") + "\"}}")</set-body>
      </otherwise>
    </choose>
  </on-error>
</policies>
