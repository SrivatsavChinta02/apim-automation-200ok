# Tenant ID is common for all envs
AZURE_TENANT_ID=

# Dev
DEV_CLIENT_ID=
DEV_CLIENT_SECRET=

# Sandbox
SANDBOX_CLIENT_ID=
SANDBOX_CLIENT_SECRET=

# Prod
PROD_CLIENT_ID=
PROD_CLIENT_SECRET=

# DR
DR_CLIENT_ID=
DR_CLIENT_SECRET=

FLASK_PORT=5050
ALLOWED_EXTENSION_ID=
# Comma-separated list of extra origins allowed to call the API (e.g. the Next.js web UI)
ALLOWED_WEB_ORIGINS=http://localhost:3000
DEFAULT_ENV=dev
PROD_SUBSCRIPTION_ID=
PROD_RESOURCE_GROUP=
DR_SUBSCRIPTION_ID=
DR_RESOURCE_GROUP=

# Admin credentials for Settings page access
ADMIN_USERNAME=
ADMIN_PASSWORD=

# Smart Assistant (Anthropic API)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Logging
LOG_LEVEL=INFO
